<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="jetbot_mirea">

    <!-- Массы и радиусы малых колес -->
    <xacro:property name="wheel_small_mass" value="0.05"/>
    <xacro:property name="wheel_small_radius" value="0.014"/>

    <!-- Массы и радиусы больших колес -->
    <xacro:property name="wheel_big_mass" value="0.1"/>
    <xacro:property name="wheel_big_radius" value="0.032"/>
    <xacro:property name="wheel_big_width" value="0.022"/>
    <xacro:property name="wheel_big_gap_between_base" value="0.007"/>

    <xacro:property name="wheel_joint_damping" value="0.1"/>
    <xacro:property name="wheel_joint_friction" value="0.1"/>

    <!-- Параметры базы -->
    <xacro:property name="base_lenght" value="0.15"/>
    <xacro:property name="base_width" value="0.1"/>
    <xacro:property name="base_height" value="0.05"/>
    <xacro:property name="base_mass" value="1.0"/>

    <!-- Параметры вычислителя -->
    <xacro:property name="computer_lenght" value="0.07"/>
    <xacro:property name="computer_width" value="0.07"/>
    <xacro:property name="computer_height" value="0.07"/>
    <xacro:property name="computer_mass" value="0.5"/>

    <!-- Параметры лидара -->
    <xacro:property name="lidar_height" value="0.03"/>
    <xacro:property name="lidar_radius" value="0.07"/>
    <xacro:property name="lidar_mass" value="0.2"/>
    
    <!-- Параметры задней камеры -->
    <xacro:property name="back_camera_lenght" value="0.02"/>
    <xacro:property name="back_camera_width" value="0.02"/>
    <xacro:property name="back_camera_height" value="0.02"/>
    <xacro:property name="back_camera_mass" value="0.05"/>

    

    <!-- "Импорты" модулей -->
    <xacro:include filename="$(find realsense_ros_gazebo)/xacro/depthcam.xacro"/>
    <xacro:include filename="$(find jetbot_mirea_description)/urdf/common_properties.xacro"/>
    <xacro:include filename="$(find jetbot_mirea_description)/urdf/gazebo_properties.xacro"/>


    <link name="base_footprint"/>
    
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0.0 0.0 ${wheel_big_radius + base_height/2}" rpy="0 0 0"/>
    </joint>

    <link name="base_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${base_lenght} ${base_width} ${base_height}"/>
            </geometry>
            <material name="acid_green"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${base_lenght} ${base_width} ${base_height}"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="${base_mass}" x="${base_lenght}" y="${base_width}" z="${base_height}">
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>


    <joint name="computer_joint" type="fixed">
        <parent link="base_link"/>
        <child link="computer_link"/>
        <origin xyz="-0.05 0.0 ${base_height/2 + computer_height/2}" rpy="0 0 0"/>
    </joint>
    
    <link name="computer_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${computer_lenght} ${computer_width} ${computer_height}"/>
            </geometry>
            <material name="acid_green"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${computer_lenght} ${computer_width} ${computer_height}"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="${computer_mass}" x="${computer_lenght}" y="${computer_width}" z="${computer_height}">
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- Фронтальная камера -->
    <xacro:realsense_d435 sensor_name="d435" parent_link="computer_link" rate="10">
    <origin xyz="${computer_lenght/2} 0.0 ${computer_height/2}" rpy="0 0 0"/>
    </xacro:realsense_d435>

    <!-- IMU-блок (вшит в камеру) -->
    <joint name="imu_joint" type="fixed">
        <parent link="d435_link"/>
        <child link="imu_link"/>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0 "/>    
    </joint>

    <link name="imu_link"/>


    <!-- Задняя камера -->
    <joint name="back_camera_joint" type="fixed">
        <parent link="computer_link"/>
        <child link="back_camera_link"/>
        <origin xyz="-${computer_lenght/2 + back_camera_lenght/2} 0.0 ${computer_height/2}" rpy="0 0 3.14"/>
    </joint>

    <link name="back_camera_link">
        <visual>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${back_camera_lenght} ${back_camera_width} ${back_camera_height}"/>
            </geometry>
            <material name="orange"/>
        </visual>

        <collision>
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
            <geometry>
                <box size="${back_camera_lenght} ${back_camera_width} ${back_camera_height}"/>
            </geometry>
        </collision>

        <xacro:inertial_box mass="${back_camera_mass}" x="${back_camera_lenght}" y="${back_camera_width}" z="${back_camera_height}">
            <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
        </xacro:inertial_box>
    </link>

    <!-- Лидар -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0.07 0.0 ${base_height/2 + lidar_height/2}" rpy="0 0 0"/>  <!-- Поворот на -90° вокруг X -->

    </joint>

    <link name="lidar_link">
        <visual>
            <origin xyz="0.0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${lidar_height}" radius="${lidar_radius/2}"/>
            </geometry>
            <material name="orange"/>
        </visual>
       
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${lidar_height}" radius="${lidar_radius/2}"/>
            </geometry>
        </collision>
        
        <xacro:inertial_cylinder mass="${lidar_mass}" length="${lidar_height}" radius="${lidar_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>


    <!-- Основные приводные колеса -->

    <!-- Левое большое колесо -->
    <joint name="wheel_left_joint" type="continuous">
        <axis xyz="0 0 1"/>
        <origin xyz="0.0 ${base_width/2 + wheel_big_width/2 + wheel_big_gap_between_base} ${-base_height/2}" rpy="-1.57 0 0"/>  <!-- Поворот на -90° вокруг X -->
        <parent link="base_link"/>
        <child link="wheel_left_link"/>
        <dynamics damping="${wheel_joint_damping}" friction="${wheel_joint_friction}"/>
        <limit effort="100" velocity="100"/>
    </joint>

    <link name="wheel_left_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${wheel_big_width}" radius="${wheel_big_radius}"/>
            </geometry>
            <material name="dark"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${wheel_big_width}" radius="${wheel_big_radius}"/>
            </geometry>
        </collision>

        <xacro:inertial_cylinder mass="${wheel_big_mass}" length="${wheel_big_width}" radius="${wheel_big_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>


    <!-- Правое большое колесо -->
    <joint name="wheel_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_right_link"/>
        <origin xyz="0.0 -${base_width/2 + wheel_big_width/2 + wheel_big_gap_between_base} ${-base_height/2}" rpy="-1.57 0 0"/>  <!-- Поворот на -90° вокруг X -->
        <axis xyz="0 0 1"/> 
        <dynamics damping="${wheel_joint_damping}" friction="${wheel_joint_friction}"/>
        <limit effort="100" velocity="100"/>
    </joint>

    <link name="wheel_right_link">
        <visual>
            <origin xyz="0.0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${wheel_big_width}" radius="${wheel_big_radius}"/>
            </geometry>
            <material name="dark"/>
        </visual>
       
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="${wheel_big_width}" radius="${wheel_big_radius}"/>
            </geometry>
        </collision>
        
        <xacro:inertial_cylinder mass="${wheel_big_mass}" length="${wheel_big_width}" radius="${wheel_big_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>


    <!-- ПЕРЕДНЕЕ РОЛИКОВОЕ КОЛЕСО (свободное вращение по 3 степеням свободы) -->

    <joint name="wheel_forward_roll_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_forward_roll_link"/>
        <origin xyz="${base_lenght/2 - wheel_small_radius} 0.0 -${base_height/2 + wheel_small_radius + 0.001}" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>  <!-- Ось вращения X - для свободного вращения -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

    <joint name="wheel_forward_pitch_joint" type="continuous">
        <parent link="wheel_forward_roll_link"/>
        <child link="wheel_forward_pitch_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <!-- Ось вращения (Pitch) -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

    <joint name="wheel_forward_yaw_joint" type="continuous">
        <parent link="wheel_forward_pitch_link"/>
        <child link="wheel_forward_yaw_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/> <!-- Ось вращения (Yaw) -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

    <joint name="wheel_forward_joint" type="fixed">
        <parent link="wheel_forward_yaw_link"/>
        <child link="wheel_forward_link"/>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0 "/>    
    </joint>

    <!-- Вспомогательные звенья -->
    <link name="wheel_forward_roll_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <link name="wheel_forward_pitch_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <link name="wheel_forward_yaw_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>

    <link name="wheel_forward_link">
        <visual>
            <origin xyz="0.0 0 0" rpy="1.5708 0 0"/>  <!-- Повернуть на 90° чтобы колесо лежало -->
            <geometry>
                <sphere radius="${wheel_small_radius}"/>
            </geometry>
            <material name="silver"/>
        </visual>
       
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <sphere radius="${wheel_small_radius}"/>
            </geometry>
        </collision>
        
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>


    <!-- ЗАДНЕЕ РОЛИКОВОЕ КОЛЕСО (свободное вращение по 3 степеням свободы) -->
    <joint name="wheel_backward_roll_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_backward_roll_link"/>
        <origin xyz="-${base_lenght/2 - wheel_small_radius} 0.0 -${base_height/2 + wheel_small_radius + 0.001}" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>  <!-- Ось вращения X - для свободного вращения -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

        <joint name="wheel_backward_pitch_joint" type="continuous">
        <parent link="wheel_backward_roll_link"/>
        <child link="wheel_backward_pitch_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/> <!-- Ось вращения (Pitch) -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

    <joint name="wheel_backward_yaw_joint" type="continuous">
        <parent link="wheel_backward_pitch_link"/>
        <child link="wheel_backward_yaw_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/> <!-- Ось вращения (Yaw) -->
        <dynamics damping="0.01" friction="0.01"/>  <!-- Меньше демпфирование для свободного вращения -->
        <limit effort="0.1" velocity="100"/>
    </joint>

    <joint name="wheel_backward_joint" type="fixed">
        <parent link="wheel_backward_yaw_link"/>
        <child link="wheel_backward_link"/>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0 "/>    
    </joint>

    <!-- Вспомогательные звенья -->
    <link name="wheel_backward_roll_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <link name="wheel_backward_pitch_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>
    <link name="wheel_backward_yaw_link">
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>

    <link name="wheel_backward_link">
        <visual>
            <origin xyz="0.0 0 0" rpy="1.5708 0 0"/>  <!-- Повернуть на 90° чтобы колесо лежало -->
            <geometry>
                <sphere radius="${wheel_small_radius}"/>
            </geometry>
            <material name="silver"/>
        </visual>
       
        <collision>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
            <geometry>
                <sphere radius="${wheel_small_radius}"/>
            </geometry>
        </collision>
        
        <xacro:inertial_sphere mass="${wheel_small_mass}" radius="${wheel_small_radius}">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>


</robot>
